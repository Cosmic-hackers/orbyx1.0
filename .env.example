# Space-Track.org API Credentials
SPACETRACK_USERNAME=your_username
SPACETRACK_PASSWORD=your_password

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# Database
DATABASE_URL=sqlite:///data/satellites.db

# FastAPI
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=true

# Streamlit
STREAMLIT_PORT=8501

# Logging
LOG_LEVEL=INFO
LOG_DIR=logs

# Collision Detection
COLLISION_THRESHOLD_KM=10.0
ANALYSIS_WINDOW_HOURS=24
PROPAGATION_STEP_MINUTES=1

# Ground Station (default: NASA Kennedy Space Center)
GROUND_STATION_LAT=28.5721
GROUND_STATION_LON=-80.6480
GROUND_STATION_ELEVATION_M=3.0
GROUND_STATION_NAME=Kennedy Space Center

# Cache TTL (seconds)
TLE_CACHE_TTL=3600
ANALYSIS_CACHE_TTL=1800
